# ── Supabase (Milestone 2) ────────────────────────────────────────────────
# Project settings → API. The anon key is safe for the browser; RLS is the
# security boundary. The service role key bypasses RLS — server only, never
# expose it to the client.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Anthropic (Milestones 3–4) ────────────────────────────────────────────
# Used server-side for chat completions and the RAG pipeline.
ANTHROPIC_API_KEY=

# ── Embeddings (Milestone 3) ──────────────────────────────────────────────
# Provider key for the embedding model used to vectorize document chunks.
VOYAGE_API_KEY=

# ── Stripe (Milestone 6) ──────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ── App ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Feature flags ─────────────────────────────────────────────────────────
# Set to "true" only after Google OAuth credentials are configured in the
# Supabase dashboard (Authentication → Providers → Google) AND the
# production redirect URL is whitelisted. When absent or not "true", the
# Google button shows a toast and never calls signInWithOAuth.
NEXT_PUBLIC_GOOGLE_OAUTH_ENABLED=false
